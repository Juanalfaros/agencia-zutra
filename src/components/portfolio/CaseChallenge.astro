---
import type { ZutraCaseStudy } from "@/types/project-types";

interface Props {
    project: ZutraCaseStudy;
}

const { project } = Astro.props;
---

{
    project.challenge && (
        <section class="case-challenge">
            <div class="container">
                <div class="challenge-layout">
                    <div class="challenge-main">
                        <h2 class="section-title">El Desafío</h2>
                        <div class="text-content">
                            <div class="description-text" set:html={project.challenge}></div>
                            {project.problemStatement && (
                                <div class="problem-statement">
                                    <h3 class="subsection-title">
                                        Problem Statement
                                    </h3>
                                    <p set:html={project.problemStatement} />
                                </div>
                            )}
                        </div>
                    </div>
                    {project.challenges && project.challenges.length > 0 && (
                        <div class="challenge-sidebar">
                            <h3 class="subsection-title">Puntos Críticos</h3>
                            <ul class="challenge-list">
                                {project.challenges.map((item: string) => (
                                    <li>
                                        <i class="ph ph-warning-circle" />{" "}
                                        {item}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )}
                </div>
            </div>
        </section>
    )
}

<style>
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .section-title {
        font-size: 2.75rem;
        font-weight: 800;
        margin-bottom: 3rem;
        color: var(--color-secondary);
        letter-spacing: -0.02em;
    }

    .subsection-title {
        font-size: 1.35rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: var(--color-accent);
        display: block;
    }

    .case-challenge {
        padding: 8rem 0;
    }

    .challenge-layout {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 6rem;
        align-items: start;
    }

    .description-text {
        font-size: 1.35rem;
        line-height: 1.8;
        color: var(--color-muted);
    }

    /* Rich Text Content Styles */
    .description-text :global(p) {
        margin-bottom: 1.5rem;
        line-height: 1.8;
    }

    .description-text :global(p:last-child) {
        margin-bottom: 0;
    }

    .description-text :global(strong),
    .description-text :global(b) {
        color: var(--color-secondary);
        font-weight: 700;
    }

    .description-text :global(em),
    .description-text :global(i) {
        color: var(--color-accent);
        font-style: italic;
    }

    .description-text :global(a) {
        color: var(--color-accent);
        text-decoration: none;
        border-bottom: 2px solid transparent;
        transition: all 0.2s ease;
        font-weight: 600;
    }

    .description-text :global(a:hover) {
        border-bottom-color: var(--color-accent);
    }

    .description-text :global(ul),
    .description-text :global(ol) {
        margin: 1.5rem 0;
        padding-left: 1.5rem;
    }

    .description-text :global(ul) {
        list-style: none;
    }

    .description-text :global(ul li) {
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 0.75rem;
    }

    .description-text :global(ul li::before) {
        content: "→";
        position: absolute;
        left: 0;
        color: var(--color-accent);
        font-weight: 700;
    }

    .description-text :global(ol li) {
        margin-bottom: 0.75rem;
        padding-left: 0.5rem;
    }

    .description-text :global(ol li::marker) {
        color: var(--color-accent);
        font-weight: 700;
    }

    .description-text :global(blockquote) {
        background: var(--color-subtle);
        border-left: 4px solid var(--color-accent);
        padding: 1.5rem 2rem;
        margin: 2rem 0;
        border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
        font-style: italic;
        color: var(--color-secondary);
    }

    .description-text :global(code) {
        background: var(--color-surface);
        padding: 0.2rem 0.5rem;
        border-radius: var(--radius-sm);
        font-family: var(--font-mono, monospace);
        font-size: 0.9em;
        color: var(--color-accent);
    }

    .description-text :global(hr) {
        border: none;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--color-line), transparent);
        margin: 2.5rem 0;
    }

    .problem-statement {
        background: var(--color-subtle);
        padding: 2.5rem;
        border-radius: var(--radius-xl);
        border-left: 5px solid var(--color-accent);
        margin-top: 4rem;
    }

    .problem-statement :global(p) {
        font-size: 1.15rem;
        line-height: 1.7;
        color: var(--color-muted);
        margin: 0;
    }

    .problem-statement :global(strong),
    .problem-statement :global(b) {
        color: var(--color-secondary);
    }

    .problem-statement :global(a) {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 3px;
        font-weight: 600;
    }

    .problem-statement :global(em),
    .problem-statement :global(i) {
        color: var(--color-accent);
    }

    .challenge-sidebar {
        background: var(--color-surface);
        padding: 2.5rem;
        border-radius: var(--radius-2xl);
        border: 1px solid var(--color-line);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .challenge-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .challenge-list li {
        display: flex;
        gap: 1rem;
        line-height: 1.5;
        color: var(--color-muted);
        font-size: 1.1rem;
    }

    .challenge-list li i {
        color: var(--color-accent);
        flex-shrink: 0;
        font-size: 1.4rem;
        margin-top: 0.2rem;
    }

    @media (max-width: 1024px) {
        .challenge-layout {
            grid-template-columns: 1fr;
            gap: 4rem;
        }
    }

    @media (max-width: 768px) {
        .section-title {
            font-size: 2rem;
        }
    }
</style>
