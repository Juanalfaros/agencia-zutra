---
// src/components/common/SEO.astro

interface Props {
    title?: string;
    description?: string;
    image?: string;
    canonicalURL?: URL | string;
    keywords?: string;
    type?: string;
}

// Con un 301 activo de .cl a .agency, la URL base siempre debe ser .agency
const siteBase = "https://zutra.agency";
const canonicalURL = new URL(Astro.url.pathname, siteBase);

const {
    title = "Zutra Agency — Diseño Valiente & Tecnología de Alto Rendimiento",
    description = "Tu partner digital de ejecución. Desarrollo web ultrarrápido, automatización de ventas y branding con carácter. Sin humo: creamos los activos que tu negocio necesita.",
    image = "/og-image.jpg",
    keywords = "Zutra Agency, Agencia Zutra Chile, desarrollo web chile, diseño web santiago, email marketing, branding corporativo, automatización, astro web, partner digital",
    type = "website",
} = Astro.props;

const siteName = "Zutra Agency Chile";
const twitterHandle = "@zutra_agency"; 
---

<meta charset="utf-8" />
<meta
    name="viewport"
    content="width=device-width, initial-scale=1, viewport-fit=cover"
/>
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="generator" content={Astro.generator} />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="description" content={description} />
{keywords && <meta name="keywords" content={keywords} />}

<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:site_name" content={siteName} />
{type === "article" && (
    <>
        <meta property="article:published_time" content={new Date().toISOString()} />
        <meta property="article:modified_time" content={new Date().toISOString()} />
    </>
)}

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />
{twitterHandle && <meta property="twitter:site" content={twitterHandle} />}

<meta name="theme-color" content="#111111" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Zutra" />
<meta name="mobile-web-app-capable" content="yes" />
