---
// src/components/landing/JsonLD.astro
interface Props {
  showFAQ?: boolean;
}

const { showFAQ = false } = Astro.props;
---
<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Zutra Agency",
    "alternateName": "Agencia Zutra",
    "brand": {
      "@type": "Brand",
      "name": "Zutra"
    },
    "description": "Zutra Agency es una firma de diseño y tecnología basada en Chile, especializada en marketing digital, desarrollo web de alto rendimiento y branding estratégico para negocios que buscan escalar con activos digitales sólidos.",
    "url": "https://zutra.agency/",
    "logo": "https://zutra.agency/og-image.jpg",
    "priceRange": "$$",
    "founders": [
      { "@type": "Person", "name": "Camilo Bustamante" },
      { "@type": "Person", "name": "Juan Alfaro" }
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Santiago",
      "addressRegion": "RM",
      "addressCountry": "CL"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -33.4489,
      "longitude": -70.6693
    },
    "sameAs": [
      "https://www.instagram.com/tuagenciazutra/",
      "https://www.tiktok.com/@tuagenciazutra",
      "https://www.linkedin.com/company/agenciazutra"
    ]
  }
</script>
{showFAQ && (
<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Si Zutra es nueva, ¿por qué confiar?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Mostramos trabajo real previo de los fundadores (rol, contexto, aportes), fijamos KPIs por escrito y trabajamos con tableros compartidos. La auditoría entrega valor inmediato y no exige permanencia."
        }
      },
      {
        "@type": "Question",
        "name": "¿Trabajan fuera de Santiago?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. Operamos remoto con sesiones en vivo y tableros compartidos. Producciones presenciales según ciudad."
        }
      },
      {
        "@type": "Question",
        "name": "¿Hay permanencia mínima?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Sprints cerrados y planes mensuales cancelables con 15 días de aviso."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo medimos éxito?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Definimos métricas al inicio (leads, CAC, ROAS, tráfico orgánico) y reportamos en ciclos quincenales o mensuales. Lo que funciona, se escala."
        }
      }
    ]
  }
</script>
)}