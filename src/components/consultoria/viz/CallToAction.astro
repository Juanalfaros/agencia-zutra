---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
}

const {
  title = '¿Listo para implementar estas mejoras?',
  description = 'Hablemos sobre cómo ejecutar esta estrategia en tu negocio y llevar tu rendimiento al siguiente nivel.',
  buttonText = 'Agendar Sesión',
  buttonLink = '/#contacto',
} = Astro.props;
---

<section class="report-cta-footer reveal" aria-label="Llamada a la acción">
  <div class="report-cta-card">
    <span class="cta-icon" aria-hidden="true">
      <i class="ph ph-rocket-launch"></i>
    </span>
    <div class="cta-text-wrapper">
      <h3 class="cta-title">{title}</h3>
      <p class="cta-desc">{description}</p>
    </div>
    <div class="cta-action">
      <a href={buttonLink} class="cta-btn">
        {buttonText}
        <i class="ph ph-arrow-right" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</section>

<style>
  .report-cta-footer {
    margin: 4rem 0;
    width: 100%;
  }

  .report-cta-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.75rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 1.5rem;
    align-items: flex-start;
  }
  @media (min-width: 480px) {
    .report-cta-card {
      padding: 2.5rem;
      gap: 1.5rem;
    }
  }
  @media (min-width: 768px) {
    .report-cta-card {
      flex-direction: row;
      align-items: center;
      padding: 3rem;
      gap: 2.5rem;
    }
  }

  .cta-icon {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background-color: var(--color-accent-subtle);
    color: var(--color-accent);
    display: grid;
    place-items: center;
    font-size: 2rem;
    flex-shrink: 0;
  }

  .cta-text-wrapper {
    flex: 1;
  }

  .cta-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-secondary);
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .cta-desc {
    color: var(--color-gray-300);
    font-size: 1rem;
    margin: 0;
    line-height: 1.6;
  }

  .cta-action {
    flex-shrink: 0;
    width: 100%;
  }
  @media (min-width: 768px) {
    .cta-action {
      width: auto;
    }
  }

  a.cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background-color: var(--color-accent);
    color: var(--color-primary) !important;
    padding: 1rem 2rem;
    border-radius: 9999px;
    font-weight: 800;
    font-size: 1rem;
    transition:
      transform 0.3s,
      background-color 0.3s;
    text-decoration: none !important;
    width: 100%;
  }
  @media (min-width: 768px) {
    a.cta-btn {
      width: auto;
    }
  }
  a.cta-btn:hover {
    transform: translateY(-4px);
    background-color: var(--color-on-accent) !important;
    color: var(--color-accent) !important;
  }
</style>
