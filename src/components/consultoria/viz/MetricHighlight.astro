---
interface Props {
  value: string | number;
  label: string;
  sublabel?: string;
  status?: 'good' | 'warning' | 'critical' | 'opportunity' | 'neutral';
}

const { value, label, sublabel, status = 'neutral' } = Astro.props;

const getStatusClass = (status: string) => {
  switch (status) {
    case 'good':
      return 'status-good';
    case 'warning':
      return 'status-warning';
    case 'critical':
      return 'status-critical';
    case 'opportunity':
      return 'status-opportunity';
    default:
      return 'status-neutral';
  }
};

const getStatusIcon = (status: string) => {
  switch (status) {
    case 'good':
      return 'ph-check-circle';
    case 'warning':
      return 'ph-warning';
    case 'critical':
      return 'ph-warning-octagon';
    case 'opportunity':
      return 'ph-rocket-launch';
    default:
      return 'ph-info';
  }
};
---

<figure
  class={`metric-highlight ${getStatusClass(status)}`}
  aria-label={`${label}: ${value}`}
>
  <div class="metric-bg-glow" aria-hidden="true"></div>
  <i class={`ph ${getStatusIcon(status)} metric-bg-icon`} aria-hidden="true"
  ></i>

  <div class="metric-content">
    <div class="metric-val-wrapper">
      <strong class="metric-val" aria-hidden="true">{value}</strong>
    </div>
    <figcaption class="metric-text">
      <div class="metric-header">
        <i class={`ph ${getStatusIcon(status)} status-icon`} aria-hidden="true"
        ></i>
        <h3 class="metric-label">{label}</h3>
      </div>
      {sublabel && <p class="metric-sublabel">{sublabel}</p>}
    </figcaption>
  </div>
</figure>

<style>
  .metric-highlight {
    position: relative;
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 1.5rem;
    border: 1px solid;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  @media (min-width: 480px) {
    .metric-highlight {
      padding: 2rem;
      margin: 2.5rem 0;
    }
  }

  .metric-highlight:hover {
    transform: translateY(-4px);
  }

  .metric-bg-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    opacity: 0.5;
    z-index: 0;
    transition: opacity 0.3s;
  }

  .metric-highlight:hover .metric-bg-glow {
    opacity: 0.8;
  }

  .metric-bg-icon {
    position: absolute;
    right: -1rem;
    bottom: -1rem;
    font-size: 8rem;
    opacity: 0.05;
    z-index: 0;
    transform: rotate(-15deg);
    transition: transform 0.5s;
  }

  .metric-highlight:hover .metric-bg-icon {
    transform: rotate(0deg) scale(1.1);
  }

  .metric-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }
  @media (min-width: 768px) {
    .metric-content {
      flex-direction: row;
      align-items: center;
      text-align: left;
      gap: 2.5rem;
    }
  }

  .metric-val-wrapper {
    flex-shrink: 0;
  }

  .metric-val {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .metric-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
  }

  .metric-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .metric-header {
      justify-content: flex-start;
    }
  }

  .status-icon {
    font-size: 1.25rem;
  }

  .metric-label {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-secondary);
    margin: 0;
    line-height: 1.3;
  }

  .metric-sublabel {
    font-size: 0.9375rem;
    color: var(--color-gray-300);
    margin: 0;
    line-height: 1.6;
    max-width: 40ch;
  }

  /* Variantes de estado */
  .status-good {
    background-color: var(--color-surface);
    border-color: rgba(34, 197, 94, 0.2);
  }
  .status-good .metric-bg-glow {
    background: radial-gradient(
      circle at left,
      rgba(34, 197, 94, 0.15) 0%,
      transparent 70%
    );
  }
  .status-good .metric-val,
  .status-good .status-icon {
    color: var(--color-green-400);
  }

  .status-warning {
    background-color: var(--color-surface);
    border-color: rgba(251, 191, 36, 0.2);
  }
  .status-warning .metric-bg-glow {
    background: radial-gradient(
      circle at left,
      rgba(251, 191, 36, 0.15) 0%,
      transparent 70%
    );
  }
  .status-warning .metric-val,
  .status-warning .status-icon {
    color: #facc15;
  }

  .status-critical {
    background-color: var(--color-surface);
    border-color: rgba(248, 113, 113, 0.2);
  }
  .status-critical .metric-bg-glow {
    background: radial-gradient(
      circle at left,
      rgba(248, 113, 113, 0.15) 0%,
      transparent 70%
    );
  }
  .status-critical .metric-val,
  .status-critical .status-icon {
    color: var(--color-red-400);
  }

  .status-opportunity {
    background-color: var(--color-surface);
    border-color: rgba(var(--color-accent-rgb), 0.3);
  }
  .status-opportunity .metric-bg-glow {
    background: radial-gradient(
      circle at left,
      rgba(var(--color-accent-rgb), 0.15) 0%,
      transparent 70%
    );
  }
  .status-opportunity .metric-val,
  .status-opportunity .status-icon {
    color: var(--color-accent);
  }

  .status-neutral {
    background-color: var(--color-surface);
    border-color: var(--color-line);
  }
  .status-neutral .metric-bg-glow {
    background: radial-gradient(
      circle at left,
      rgba(255, 255, 255, 0.05) 0%,
      transparent 70%
    );
  }
  .status-neutral .metric-val,
  .status-neutral .status-icon {
    color: var(--color-secondary);
  }
</style>
