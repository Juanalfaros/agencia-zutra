---
interface Vital {
  metric: string;
  value: string;
  threshold: string;
  status: 'good' | 'needs-improvement' | 'poor';
}

interface Props {
  device: string;
  deviceType: 'mobile' | 'desktop';
  vitals: Vital[];
}

const { device, deviceType, vitals } = Astro.props;

const getStatusClass = (status: string) => {
  switch (status) {
    case 'good':
      return 'status-good';
    case 'needs-improvement':
      return 'status-warning';
    case 'poor':
      return 'status-poor';
    default:
      return 'status-neutral';
  }
};

const getStatusIcon = (status: string) => {
  switch (status) {
    case 'good':
      return 'ph-check-circle';
    case 'needs-improvement':
      return 'ph-warning-circle';
    case 'poor':
      return 'ph-warning-octagon';
    default:
      return 'ph-info';
  }
};
---

<section
  class="vitals-table-wrapper"
  aria-label={`Core Web Vitals — ${device}`}
>
  <header class="vitals-header">
    <i
      class={`ph ph-${deviceType === 'mobile' ? 'device-mobile' : 'desktop'} accent-icon`}
      aria-hidden="true"></i>
    <h4 class="vitals-title">{device}</h4>
  </header>
  <div
    class="table-scroll"
    role="region"
    aria-label={`Tabla Core Web Vitals ${device}`}
    tabindex="0"
  >
    <table class="vitals-table">
      <caption class="sr-only">Core Web Vitals para {device}</caption>
      <thead>
        <tr>
          <th scope="col">Métrica</th>
          <th scope="col">Valor</th>
          <th scope="col">Umbral Max.</th>
          <th scope="col" class="text-center">Estado</th>
        </tr>
      </thead>
      <tbody>
        {
          vitals.map((vital) => (
            <tr>
              <th scope="row" class="metric-name">
                {vital.metric}
              </th>
              <td>
                <span class={`vital-badge ${getStatusClass(vital.status)}`}>
                  {vital.value}
                </span>
              </td>
              <td class="threshold-value">{vital.threshold}</td>
              <td class="text-center">
                <i
                  class={`ph ${getStatusIcon(vital.status)} status-icon ${getStatusClass(vital.status)}`}
                  aria-label={vital.status}
                />
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>

<style>
  .vitals-table-wrapper {
    margin: 1.5rem 0;
    overflow: hidden;
    border-radius: 1rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-line);
  }

  .vitals-header {
    padding: 1rem;
    border-bottom: 1px solid var(--color-line);
    background-color: var(--color-surface);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .accent-icon {
    font-size: 1.25rem;
    color: var(--color-accent);
  }

  .vitals-title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-secondary);
  }

  .table-scroll {
    overflow-x: auto;
  }

  .vitals-table {
    width: 100%;
    text-align: left;
    border-collapse: collapse;
  }

  .vitals-table th {
    padding: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-gray-300);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
    border-bottom: 1px solid var(--color-line);
    background-color: var(--color-primary);
  }
  @media (min-width: 640px) {
    .vitals-table th {
      padding: 1rem;
      font-size: 0.875rem;
    }
  }

  .vitals-table td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--color-line);
  }
  @media (min-width: 640px) {
    .vitals-table td {
      padding: 1rem;
    }
  }

  .vitals-table tbody tr {
    transition: background-color 0.2s;
  }
  .vitals-table tbody tr:hover {
    background-color: var(--color-surface-subtle);
  }
  .vitals-table tbody tr:last-child td {
    border-bottom: none;
  }

  .metric-name {
    font-weight: 500;
    color: var(--color-secondary);
  }

  .vital-badge {
    display: inline-flex;
    padding: 0.25rem 0.625rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 700;
    border: 1px solid;
  }

  .threshold-value {
    color: var(--color-gray-300);
    font-size: 0.875rem;
  }

  .text-center {
    text-align: center;
  }

  .status-icon {
    font-size: 1.25rem;
    border: none !important;
    background: transparent !important;
  }

  .status-good {
    color: var(--color-green-500);
    background-color: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.2);
  }
  .status-warning {
    color: #fbbf24;
    background-color: rgba(251, 191, 36, 0.1);
    border-color: rgba(251, 191, 36, 0.2);
  }
  .status-poor {
    color: var(--color-red-400);
    background-color: rgba(248, 113, 113, 0.1);
    border-color: rgba(248, 113, 113, 0.2);
  }
  .status-neutral {
    color: var(--color-gray-300);
    background-color: var(--color-surface);
    border-color: var(--color-line);
  }
</style>
