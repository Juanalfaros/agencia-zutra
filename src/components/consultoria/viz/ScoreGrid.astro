---
interface Score {
  label: string;
  device: 'mobile' | 'desktop';
  performance: number;
  accessibility: number;
  practices: number;
  seo: number;
}

interface Props {
  mobile: Score;
  desktop: Score;
}

const { mobile, desktop } = Astro.props;

const getScoreColor = (score: number) => {
  if (score >= 90) return 'var(--color-green-500)';
  if (score >= 50) return '#eab308';
  return 'var(--color-red-400)';
};

const radius = 24;
const circumference = 2 * Math.PI * radius;
---

<section class="score-grid" aria-label="Puntuaciones PageSpeed">
  {
    [mobile, desktop].map((data) => (
      <article class="score-card">
        <header class="score-card-header">
          <span class="icon-box" aria-hidden="true">
            <i
              class={`ph-duotone ph-${data.device === 'mobile' ? 'device-mobile' : 'desktop'} accent-icon`}
            />
          </span>
          <h3 class="score-card-title">{data.label}</h3>
        </header>

        <div class="metrics-grid">
          {[
            { label: 'Rendimiento', value: data.performance },
            { label: 'Accesibilidad', value: data.accessibility },
            { label: 'Prácticas', value: data.practices },
            { label: 'SEO', value: data.seo },
          ].map((stat) => {
            const offset = circumference - (stat.value / 100) * circumference;
            const color = getScoreColor(stat.value);

            return (
              <figure
                class="metric-box"
                aria-label={`${stat.label}: ${stat.value} de 100`}
              >
                <div class="gauge-container" aria-hidden="true">
                  <svg
                    class="gauge-svg"
                    viewBox="0 0 64 64"
                    role="presentation"
                  >
                    <circle
                      class="gauge-bg"
                      cx="32"
                      cy="32"
                      r={radius}
                      stroke="var(--color-surface-subtle)"
                    />
                    <circle
                      class="gauge-progress"
                      cx="32"
                      cy="32"
                      r={radius}
                      stroke={color}
                      stroke-dasharray={circumference}
                      stroke-dashoffset={offset}
                    />
                  </svg>
                  <span class="gauge-value" style={`color: ${color}`}>
                    {stat.value}
                  </span>
                </div>
                <figcaption class="metric-label">{stat.label}</figcaption>
              </figure>
            );
          })}
        </div>
      </article>
    ))
  }
</section>

<style>
  .score-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
  }
  @media (min-width: 768px) {
    .score-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .score-card {
    padding: 1.5rem;
    border-radius: 1rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-line);
    transition: transform 0.3s;
  }
  .score-card:hover {
    transform: translateY(-4px);
  }

  .score-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .icon-box {
    padding: 0.5rem;
    border-radius: 0.5rem;
    background-color: var(--color-primary);
  }

  .accent-icon {
    font-size: 1.5rem;
    color: var(--color-accent);
  }

  .score-card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    color: var(--color-secondary);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (min-width: 480px) {
    .metrics-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .metric-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 0.5rem;
    text-align: center;
  }

  .gauge-container {
    position: relative;
    width: 64px;
    height: 64px;
    margin-bottom: 0.5rem;
  }

  .gauge-svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .gauge-bg {
    fill: none;
    stroke-width: 4;
  }

  .gauge-progress {
    fill: none;
    stroke-width: 4;
    stroke-linecap: round;
    transition: stroke-dashoffset 1s ease-out;
  }

  .gauge-value {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 1.125rem;
    font-weight: 800;
    font-family: monospace;
  }

  .metric-label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-300);
    line-height: 1.2;
  }
</style>
