---
// src/pages/preview/blog/[slug].astro
import Layout from "@/layouts/Layout.astro";
import BlogPage from "@/pages/blog/[slug].astro";
import { getEntries, getEntriesByField } from "@/lib/contentful";
import { adaptBlogPost } from "@/lib/contentful-adapters";

export const prerender = false;

const { slug } = Astro.params;
const previewCookie = Astro.cookies.get("contentful_preview")?.value === "true";

if (!previewCookie) {
    return Astro.redirect(`/blog/${slug}`);
}

// Fetch the draft content explicitly
const entries = await getEntriesByField("blogPost", "slug", slug!, true, Astro);
if (entries.items.length === 0) {
    return new Response("Post not found in preview mode", { status: 404 });
}

const post = adaptBlogPost(entries.items[0]);

// Fetch all posts for the related section
const allEntries = await getEntries(
    "blogPost", 
    { order: "-fields.publishDate" }, 
    true, 
    Astro
);
const allPosts = allEntries.items.map(adaptBlogPost);
---

<BlogPage post={post} allPosts={allPosts} />
