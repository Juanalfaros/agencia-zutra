---
import Layout from '@/layouts/Layout.astro';
import { getEntries, isPreviewEnabled } from '@/lib/contentful';
import { adaptRecurso } from '@/lib/contentful-adapters';
import type { ZutraRecurso } from '@/types/recurso-types';

const isPreview = isPreviewEnabled(Astro);
const entries = await getEntries(
  'recurso',
  { order: 'fields.order' },
  isPreview
);
const recursos = entries.items.map(adaptRecurso);

const CATEGORY_LABELS: Record<string, string> = {
  template: 'Template',
  'ui-kit': 'UI Kit',
  auditoria: 'Auditoría',
  guia: 'Guía',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Recursos digitales — Zutra',
  itemListElement: recursos.map((r, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: r.title,
      description: r.description,
      image: r.featuredImage?.src ?? '',
      url: `https://zutra.agency/recursos/${r.slug}`,
      offers: {
        '@type': 'Offer',
        price: r.isFree ? '0' : r.price.replace(/[^0-9.]/g, '') || '0',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
        url: r.gumroadUrl,
      },
    },
  })),
};
---

<Layout
  title="Recursos Digitales | Zutra — Templates, Kits y Guías"
  description="Templates Astro, UI kits y guías de crecimiento digital. Recursos listos para usar creados por el equipo de Zutra."
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(itemListSchema)}
  />

  <main class="page">
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <span class="hero__badge">Productos Digitales</span>
        <h1 class="hero__title">
          Construye más rápido con<br /><span class="accent"
            >recursos de Zutra</span
          >
        </h1>
        <p class="hero__sub">
          Templates Astro, UI kits, auditorías empaquetadas y guías de
          crecimiento.<br />
          Creados por el equipo que los usa en producción.
        </p>
      </div>
    </section>

    <!-- Grid -->
    <section class="grid-section">
      <div class="container">
        {
          recursos.length === 0 ? (
            <p class="empty">
              Próximamente — estamos preparando los primeros recursos.
            </p>
          ) : (
            <div class="cards">
              {recursos.map((r: ZutraRecurso) => {
                const isSoon = r.status === 'coming-soon';
                const catLabel = CATEGORY_LABELS[r.category] ?? r.category;
                return (
                  <article class:list={['card', isSoon && 'card--soon']}>
                    {/* Imagen */}
                    <a
                      href={`/recursos/${r.slug}`}
                      class="card__img-wrap"
                      aria-label={`Ver ${r.title}`}
                      tabindex={isSoon ? -1 : 0}
                    >
                      {r.featuredImage ? (
                        <img
                          src={r.featuredImage.src}
                          alt={r.featuredImage.alt}
                          class="card__img"
                          loading="lazy"
                          decoding="async"
                        />
                      ) : (
                        <div class="card__img-empty">
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="32"
                            height="32"
                            viewBox="0 0 256 256"
                            aria-hidden="true"
                          >
                            <path
                              fill="currentColor"
                              d="M216 40H40a16 16 0 0 0-16 16v144a16 16 0 0 0 16 16h176a16 16 0 0 0 16-16V56a16 16 0 0 0-16-16Zm0 16v102.75l-26.07-26.06a16 16 0 0 0-22.63 0l-20 20-44-44a16 16 0 0 0-22.62 0L40 149.37V56ZM40 216v-44l52-52 44 44a8 8 0 0 0 11.31 0l28.69-28.69 26.07 26.07.62.62V216Z"
                            />
                          </svg>
                        </div>
                      )}
                      {isSoon && (
                        <div class="card__soon">
                          <span>Próximamente</span>
                        </div>
                      )}
                      <div class="card__badge-wrap">
                        {r.isFree ? (
                          <span class="badge badge--free">Gratis</span>
                        ) : (
                          r.price && (
                            <span class="badge badge--price">{r.price}</span>
                          )
                        )}
                      </div>
                    </a>

                    {/* Contenido */}
                    <div class="card__body">
                      <div class="card__meta">
                        <span class="cat-pill">{catLabel}</span>
                        {r.techStack.slice(0, 3).map((tech) => (
                          <span class="tech-chip">{tech}</span>
                        ))}
                      </div>

                      <h2 class="card__title">
                        <a href={`/recursos/${r.slug}`}>{r.title}</a>
                      </h2>

                      <p class="card__desc">{r.description}</p>

                      <div class="card__actions">
                        {r.demoUrl && !isSoon && (
                          <a
                            href={r.demoUrl}
                            class="btn-ghost"
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            Demo ↗
                          </a>
                        )}
                        <a
                          href={isSoon ? `/recursos/${r.slug}` : r.gumroadUrl}
                          class:list={['btn-accent', isSoon && 'btn--disabled']}
                          target={isSoon ? undefined : '_blank'}
                          rel={isSoon ? undefined : 'noopener noreferrer'}
                          aria-disabled={isSoon}
                        >
                          {isSoon
                            ? 'Próximamente'
                            : r.isFree
                              ? 'Descargar gratis →'
                              : `Comprar ${r.price} →`}
                        </a>
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          )
        }
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="cta-banner">
      <div class="container">
        <div class="cta-banner__inner">
          <div class="cta-banner__text">
            <h2 class="cta-banner__title">
              ¿Necesitas algo completamente a medida?
            </h2>
            <p class="cta-banner__body">
              Los recursos son el punto de partida. Si tu proyecto requiere una
              solución personalizada, el equipo de Zutra está listo.
            </p>
          </div>
          <a href="/contacto" class="cta-banner__btn"
            >Hablemos de tu proyecto →</a
          >
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ── Base ────────────────────────────────────────────────────────────── */
  .page {
    background: var(--color-primary);
    color: var(--color-secondary);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .accent {
    color: var(--color-accent);
  }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero {
    padding: 6rem 0 3.5rem;
    text-align: center;
  }

  .hero__badge {
    display: inline-block;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-full);
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
    margin-bottom: 1.5rem;
  }

  .hero__title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-secondary);
    margin-bottom: 1.25rem;
  }

  .hero__sub {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── Grid ────────────────────────────────────────────────────────────── */
  .grid-section {
    padding: 2.5rem 0 5rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.75rem;
  }

  .empty {
    text-align: center;
    color: var(--color-muted);
    padding: 5rem 0;
  }

  /* ── Card ────────────────────────────────────────────────────────────── */
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      border-color 0.2s,
      transform 0.2s,
      box-shadow 0.2s;
  }

  .card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px
      color-mix(in srgb, var(--color-accent) 6%, transparent);
  }

  .card--soon {
    opacity: 0.7;
  }

  /* Image area */
  .card__img-wrap {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    text-decoration: none;
    background: var(--color-subtle);
    flex-shrink: 0;
  }

  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .card:hover .card__img {
    transform: scale(1.04);
  }

  .card__img-empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-line);
  }

  .card__soon {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-primary) 72%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card__soon span {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    padding: 0.35rem 1rem;
    border-radius: var(--radius-full);
  }

  .card__badge-wrap {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
  }

  .badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 800;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-full);
    line-height: 1;
  }

  .badge--price {
    background: var(--color-accent);
    color: var(--color-on-accent);
  }

  .badge--free {
    background: color-mix(in srgb, #19ef9c 15%, transparent);
    color: #19ef9c;
    border: 1px solid color-mix(in srgb, #19ef9c 30%, transparent);
  }

  /* Card body */
  .card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    flex: 1;
  }

  .card__meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .cat-pill {
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    padding: 0.22rem 0.6rem;
    border-radius: var(--radius-full);
    border: 1px solid color-mix(in srgb, var(--color-accent) 22%, transparent);
  }

  .tech-chip {
    font-size: 0.62rem;
    font-weight: 500;
    color: var(--color-muted);
    background: var(--color-subtle);
    padding: 0.22rem 0.55rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-line);
  }

  .card__title {
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1.25;
    margin: 0;
  }

  .card__title a {
    color: var(--color-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .card__title a:hover {
    color: var(--color-accent);
  }

  .card__desc {
    font-size: 0.855rem;
    color: var(--color-muted);
    line-height: 1.65;
    margin: 0;
  }

  .card__actions {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    flex-wrap: wrap;
    padding-top: 0.25rem;
    margin-top: auto;
  }

  /* Buttons */
  .btn-ghost {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-full);
    transition:
      border-color 0.15s,
      color 0.15s;
    white-space: nowrap;
  }

  .btn-ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .btn-accent {
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--color-on-accent);
    background: var(--color-accent);
    text-decoration: none;
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-full);
    transition: background 0.15s;
    white-space: nowrap;
  }

  .btn-accent:hover {
    background: var(--color-accent-hover);
  }

  .btn--disabled {
    opacity: 0.45;
    pointer-events: none;
    cursor: default;
  }

  /* ── CTA Banner ──────────────────────────────────────────────────────── */
  .cta-banner {
    border-top: 1px solid var(--color-line);
    padding: 4rem 0 5rem;
  }

  .cta-banner__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-banner__text {
    max-width: 560px;
  }

  .cta-banner__title {
    font-size: clamp(1.35rem, 3vw, 1.9rem);
    font-weight: 900;
    color: var(--color-secondary);
    margin-bottom: 0.6rem;
    letter-spacing: -0.02em;
  }

  .cta-banner__body {
    color: var(--color-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .cta-banner__btn {
    flex-shrink: 0;
    background: transparent;
    border: 2px solid var(--color-accent);
    color: var(--color-accent);
    font-weight: 800;
    font-size: 0.9rem;
    padding: 0.85rem 2rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    white-space: nowrap;
    transition:
      background 0.15s,
      color 0.15s;
  }

  .cta-banner__btn:hover {
    background: var(--color-accent);
    color: var(--color-on-accent);
  }
</style>
