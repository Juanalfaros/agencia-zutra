---
import Layout from '@/layouts/Layout.astro';
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import SlidesModal from '@/components/consultoria/SlidesModal.astro';
import ReportGate from '@/components/consultoria/ReportGate.astro';
import { verifyToken } from '@/lib/report-auth';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const entry = await getEntry('consultoria', slug);
if (!entry) return Astro.redirect('/404');

const OTP_SECRET = ((import.meta.env as any).OTP_SECRET || '').trim();

let isLocked = false;
let accessExpired = false;

if (entry.data.protected) {
  const cookieVal = Astro.cookies.get(`rs_${slug}`)?.value ?? '';
  if (!cookieVal || !OTP_SECRET) {
    isLocked = true;
  } else {
    const session = await verifyToken(cookieVal, OTP_SECRET);
    if (!session) {
      isLocked = true;
    } else if (!session.isAdmin && entry.data.accessExpiry) {
      if (new Date() > entry.data.accessExpiry!) {
        isLocked = true;
        accessExpired = true;
      }
    }
  }
}

const { Content } = await render(entry);

const isProtected = entry.data.protected;
---

<Layout
  title={`${entry.data.title} | Zutra`}
  description={entry.data.description}
  showFooter={!isLocked}
  showCTA={false}
>
  {
    isLocked ? (
      <ReportGate
        slug={slug}
        title={entry.data.title}
        category={entry.data.category}
        expired={accessExpired}
      />
    ) : (
      <>
        <div id="reading-progress" class="reading-progress" />

        <div class="bg-master">
          <div class="bg-layer topo-layer" />
          <div class="bg-layer topo-layer-2" />
        </div>

        <div class="report-wrapper">
          <article class="container report-container">
            <header class="report-header reveal">
              <div class="header-nav">
                <a href="/consultoria" class="back-link">
                  <i class="ph-duotone ph-arrow-left" /> Volver
                </a>
                <span class="dot-separator" />
                <span class="category-badge">
                  {entry.data.category.replace('-', ' ')}
                </span>
                {isProtected && (
                  <span class="protected-badge" title="Reporte Protegido">
                    <i class="ph-duotone ph-lock-key" /> Confidencial
                  </span>
                )}
              </div>
              <div class="titleImage">
                <h1 class="report-title">{entry.data.title}</h1>
                {entry.data.imageHeader && (
                  <div class="imageheader">
                    <Image
                      src={entry.data.imageHeader}
                      alt={`Imagen de portada para ${entry.data.title}`}
                      width={1200}
                      height={630}
                      loading="eager"
                    />
                  </div>
                )}
              </div>

              <dl class="report-meta-box">
                <div class="meta-col">
                  <dt class="meta-label">Cliente</dt>
                  <dd class="meta-value text-secondary">{entry.data.client}</dd>
                </div>
                <div class="meta-divider" role="separator" aria-hidden="true" />
                <div class="meta-col">
                  <dt class="meta-label">Analista</dt>
                  <dd class="meta-value">
                    <i
                      class="ph-duotone ph-user-circle accent-icon"
                      aria-hidden="true"
                    />
                    {entry.data.analyst}
                  </dd>
                </div>
                <div class="meta-divider" role="separator" aria-hidden="true" />
                <div class="meta-col">
                  <dt class="meta-label">Fecha Emisión</dt>
                  <dd class="meta-value">
                    <time datetime={entry.data.date.toISOString()}>
                      {new Date(entry.data.date).toLocaleDateString('es-ES', {
                        day: 'numeric',
                        month: 'long',
                        year: 'numeric',
                      })}
                    </time>
                  </dd>
                </div>
              </dl>
            </header>

            <div class="report-main-layout">
              <aside class="toc-sidebar">
                <div class="toc-sticky">
                  <span class="toc-label">Contenido</span>
                  <nav id="report-toc" class="toc-nav">
                    {/* Generado vía JS */}
                  </nav>
                </div>
              </aside>

              <div
                class="report-content prose reveal"
                style="transition-delay: 200ms;"
              >
                <Content />
              </div>
            </div>
          </article>
        </div>

        {entry.data.slidesEnabled &&
          entry.data.slides &&
          entry.data.slides.length > 0 && (
            <SlidesModal slides={entry.data.slides} />
          )}
      </>
    )
  }
</Layout>

<script>
  function generateTOC() {
    const content = document.querySelector('.report-content');
    const toc = document.querySelector('#report-toc');
    if (!content || !toc) return;

    const headings = content.querySelectorAll('h2');
    if (headings.length < 2) {
      document.querySelector('.toc-sidebar')?.remove();
      return;
    }

    const list = document.createElement('ul');
    headings.forEach((heading, index) => {
      const id = `section-${index}`;
      heading.id = id;

      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = heading.textContent;
      a.className = 'toc-link';
      li.appendChild(a);
      list.appendChild(li);
    });

    toc.appendChild(list);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.getAttribute('id');
          const link = document.querySelector(`.toc-link[href="#${id}"]`);
          if (entry.isIntersecting) {
            document
              .querySelectorAll('.toc-link')
              .forEach((l) => l.classList.remove('is-active'));
            link?.classList.add('is-active');
          }
        });
      },
      {
        rootMargin: '-100px 0px -70% 0px',
        threshold: 0,
      }
    );

    headings.forEach((h) => observer.observe(h));
  }

  generateTOC();

  // Barra de progreso de lectura
  window.addEventListener('scroll', () => {
    const winScroll =
      document.body.scrollTop || document.documentElement.scrollTop;
    const height =
      document.documentElement.scrollHeight -
      document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    const bar = document.getElementById('reading-progress');
    if (bar) bar.style.width = scrolled + '%';
  });
</script>

<style>
  /* --- Barra de Progreso --- */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: var(--color-accent);
    z-index: 1001;
    transition: width 0.1s ease-out;
    box-shadow: 0 0 10px rgba(var(--color-accent-rgb), 0.5);
  }

  .report-wrapper {
    position: relative;
    padding-top: 6rem;
    padding-bottom: 4rem;
    min-height: 100vh;
    overflow: clip; /* clip recorta visualmente sin romper position: sticky */
  }
  @media (min-width: 640px) {
    .report-wrapper {
      padding-top: 8rem;
      padding-bottom: 5rem;
    }
  }

  .report-container {
    position: relative;
    z-index: 10;
    max-width: 75rem;
    margin: 0 auto;
  }

  .report-header {
    margin-bottom: 2.5rem;
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
  }
  @media (min-width: 768px) {
    .report-header {
      margin-bottom: 4rem;
    }
  }

  .imageheader {
    margin: 1.5rem 0;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--color-line);
  }

  .imageheader img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    max-width: 50rem;
  }

  /* --- Layout principal: sidebar TOC + contenido --- */
  .report-main-layout {
    display: block;
    position: relative;
  }
  @media (min-width: 1280px) {
    .report-main-layout {
      display: grid;
      grid-template-columns: 13rem 1fr;
      gap: 0 3rem;
      /* Sin align-items: start — el sidebar estira al alto del contenido,
         lo que da espacio para que position: sticky funcione */
    }
  }

  /* --- Sidebar TOC --- */
  .toc-sidebar {
    display: none;
  }
  @media (min-width: 1280px) {
    .toc-sidebar {
      display: block;
    }
  }

  .toc-sticky {
    position: sticky;
    top: 7rem;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    scrollbar-width: none;
    padding-right: 0.25rem;
  }
  .toc-sticky::-webkit-scrollbar {
    display: none;
  }

  .toc-label {
    display: block;
    font-size: 0.675rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
  }

  .toc-nav :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    border-left: 1px solid var(--color-line);
  }

  .toc-nav :global(.toc-link) {
    font-size: 0.8125rem;
    color: var(--color-muted);
    text-decoration: none;
    line-height: 1.4;
    padding: 0.4rem 0 0.4rem 1rem;
    display: block;
    position: relative;
    left: -1px;
    border-left: 2px solid transparent;
    transition:
      color 0.2s ease,
      border-left-color 0.2s ease;
  }

  .toc-nav :global(.toc-link:hover) {
    color: var(--color-secondary);
    border-left-color: var(--color-line);
  }

  .toc-nav :global(.toc-link.is-active) {
    color: var(--color-accent);
    font-weight: 700;
    border-left-color: var(--color-accent);
  }

  /* --- Contenido del reporte --- */
  .report-content {
    max-width: none;
    min-width: 0; /* Evita overflow dentro del grid */
  }

  .report-content :global(> *) {
    max-width: 56rem !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }

  .report-content :global(> .options-grid) {
    max-width: 100% !important;
  }

  .header-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-muted);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 0.3s;
  }

  .back-link:hover {
    color: var(--color-secondary);
  }

  .dot-separator {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--color-line);
  }

  .category-badge {
    padding: 0.25rem 0.75rem;
    background-color: var(--color-surface);
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 9999px;
    border: 1px solid var(--color-line);
  }

  .protected-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    background-color: var(--color-error-subtle);
    color: var(--color-red-400);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 9999px;
    border: 1px solid var(--color-red-400);
  }

  .report-title {
    font-size: clamp(2rem, 7vw, 3.75rem);
    font-weight: 900;
    color: var(--color-secondary);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .report-meta-box {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem;
    border-radius: 1rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-line);
  }
  @media (min-width: 640px) {
    .report-meta-box {
      gap: 1.5rem;
      padding: 1.5rem;
    }
  }

  .meta-col {
    flex: 1;
    min-width: 130px;
  }
  @media (min-width: 480px) {
    .meta-col {
      min-width: 150px;
    }
  }

  .meta-label {
    font-size: 0.75rem;
    color: var(--color-muted);
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .meta-value {
    color: var(--color-gray-300);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .text-secondary {
    color: var(--color-secondary);
    font-size: 1.125rem;
  }

  .accent-icon {
    font-size: 1.25rem;
    color: var(--color-accent);
  }

  .meta-divider {
    display: none;
    width: 1px;
    height: 2.5rem;
    background-color: var(--color-line);
  }
  @media (min-width: 768px) {
    .meta-divider {
      display: block;
    }
  }

  .report-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    transition: text-decoration 0.2s;
  }

  .report-content :global(a:hover) {
    text-decoration: underline;
  }

  .report-content :global(img) {
    border-radius: 1rem;
    border: 1px solid var(--color-line);
  }

  .report-content :global(hr) {
    border-color: var(--color-line);
    margin: 3rem 0;
  }

  .titleImage {
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  @media (max-width: 640px) {
    .titleImage {
      flex-direction: column;
      gap: 0;
    }
  }
</style>
