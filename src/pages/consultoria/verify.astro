---
import Layout from '@/layouts/Layout.astro';
import { getEntry } from 'astro:content';
export const prerender = false;

const t = Astro.url.searchParams.get('t') ?? '';
const s = Astro.url.searchParams.get('s') ?? '';

type ErrorReason = 'missing' | 'invalid' | 'access-expired' | 'not-found';
let errorReason: ErrorReason = 'invalid';
let isVerified = false;

if (t && s) {
  try {
    // Decodificamos el token ligero: btoa(`${email}|${slug}|${timestamp}|${rawStr.length}`)
    const decoded = atob(t);
    const [email, slug, timestamp] = decoded.split('|');

    // Validamos que el slug coincida y que no hayan pasado más de 15 min
    const isRecent = Date.now() - parseInt(timestamp) < 15 * 60 * 1000;

    if (slug === s && isRecent) {
      const entry = await getEntry('consultoria', s);
      if (entry) {
        const adminEmails = (entry.data.adminEmails ?? []).map((e) =>
          e.toLowerCase()
        );
        const isAdmin = adminEmails.includes(email.toLowerCase());

        // Generamos cookie de sesión (esto sí corre bien en browser/server básico)
        const maxAgeSeconds = isAdmin ? 365 * 24 * 60 * 60 : 30 * 24 * 60 * 60;

        // Usamos una firma de sesión compatible
        const sessionToken = btoa(`${email}:${s}:${isAdmin}:${Date.now()}`);

        Astro.cookies.set(`rs_${s}`, sessionToken, {
          httpOnly: true,
          secure: true,
          sameSite: 'lax',
          maxAge: maxAgeSeconds,
          path: `/consultoria/${s}`,
        });

        isVerified = true;
      } else {
        errorReason = 'not-found';
      }
    }
  } catch (e) {
    console.error('Verify error:', e);
    errorReason = 'invalid';
  }
}

if (isVerified) {
  return Astro.redirect(`/consultoria/${s}`);
}

const errorMessages: Record<
  ErrorReason,
  { title: string; body: string; canRetry: boolean }
> = {
  missing: {
    title: 'Enlace incompleto',
    body: 'El enlace de acceso no es correcto.',
    canRetry: true,
  },
  invalid: {
    title: 'Enlace expirado',
    body: 'Este enlace ya no es válido. Los enlaces duran 10 minutos.',
    canRetry: true,
  },
  'access-expired': {
    title: 'Acceso vencido',
    body: 'El período de acceso ha finalizado.',
    canRetry: false,
  },
  'not-found': {
    title: 'No encontrado',
    body: 'El reporte no existe.',
    canRetry: false,
  },
};

const error = errorMessages[errorReason];
---

<Layout
  title="Verificando acceso | Zutra"
  description="Estamos verificando tus credenciales de acceso..."
  showFooter={false}
  showCTA={false}
>
  <div class="verify-wrapper">
    <div class="verify-card">
      <span class="verify-icon">
        <i class="ph-duotone ph-warning"></i>
      </span>
      <h1 class="verify-title">{error.title}</h1>
      <p class="verify-body">{error.body}</p>
      <div class="verify-actions">
        {
          error.canRetry && s && (
            <a href={`/consultoria/${s}`} class="btn-primary">
              Solicitar nuevo enlace
            </a>
          )
        }
        <a href="/consultoria" class="btn-ghost">Volver</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .verify-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .verify-card {
    max-width: 28rem;
    width: 100%;
    text-align: center;
    padding: 3rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 1.5rem;
  }
  .verify-icon {
    font-size: 3rem;
    color: var(--color-red-400);
    margin-bottom: 1.5rem;
    display: block;
  }
  .verify-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-secondary);
    margin-bottom: 1rem;
  }
  .verify-body {
    color: var(--color-gray-300);
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  .verify-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .btn-primary {
    background: var(--color-accent);
    color: var(--color-primary);
    padding: 1rem;
    border-radius: 99px;
    font-weight: 700;
    text-decoration: none;
  }
  .btn-ghost {
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.9rem;
  }
</style>
