---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { verifyToken } from '@/lib/report-auth';
import { env as cfEnv } from 'cloudflare:workers';
import ReportGate from '@/components/consultoria/ReportGate.astro';

export const prerender = false;

const adminCookie = Astro.cookies.get('zutra_admin')?.value ?? '';
const OTP_SECRET = ((import.meta.env as any).OTP_SECRET || '').trim();
const adminSession = await verifyToken(adminCookie, OTP_SECRET);
const isAdmin = adminSession?.isAdmin === true;

const allConsultorias = await getCollection('consultoria');
const publishedConsultorias = allConsultorias.filter(
  (c) => c.data.status === 'published'
);

// Leer logs de acceso desde KV para cada reporte
type AccessLog = { email: string; ts: number; ua: string };
const REPORT_LOGS = (cfEnv as any).REPORT_LOGS as
  | { get: (key: string, opts: { type: 'json' }) => Promise<unknown> }
  | undefined;

const accessLogs: Record<string, AccessLog[]> = {};
if (REPORT_LOGS) {
  await Promise.all(
    publishedConsultorias.map(async (report) => {
      const logs = (await REPORT_LOGS.get(`log_${report.id}`, {
        type: 'json',
      })) as AccessLog[] | null;
      accessLogs[report.id] = Array.isArray(logs) ? logs : [];
    })
  );
}
---

<Layout
  title="Consultoría Estratégica Digital | Zutra"
  description="Reportes y auditorías técnicas para clientes de Zutra Agency."
  showFooter={isAdmin}
  showCTA={false}
>
  {
    !isAdmin ? (
      <ReportGate slug="__admin__" title="Panel Admin" category="admin" />
    ) : (
      <>
        <div class="bg-master">
          <div class="bg-layer topo-layer" />
          <div class="bg-layer topo-layer-2" />
        </div>

        <div class="consultoria-wrapper">
          <div class="container consultoria-container">
            <div class="consultoria-header reveal">
              <div class="admin-topbar">
                <span class="admin-badge">
                  <i class="ph-duotone ph-shield-check" /> Panel Admin
                </span>
                <form
                  method="POST"
                  action="/consultoria/logout"
                  style="display:contents"
                >
                  <button type="submit" class="admin-logout">
                    <i class="ph-duotone ph-sign-out" /> Cerrar sesión
                  </button>
                </form>
              </div>
              <h1 class="consultoria-title">
                Auditorías <span class="accent-text">Técnicas</span>
              </h1>
              <p class="consultoria-subtitle">
                Plataforma de reportes y diagnóstico digital. Acceso exclusivo
                para clientes y partners estratégicos.
              </p>
            </div>

            <div
              class="consultoria-grid reveal"
              style="transition-delay: 200ms;"
            >
              {publishedConsultorias.map((report) => (
                <a href={`/consultoria/${report.id}`} class="report-card">
                  <div class="report-card-glow" />
                  <div class="report-card-content">
                    <div class="report-card-top">
                      <span class="report-badge">
                        {report.data.category.replace('-', ' ')}
                      </span>
                      <i class="ph ph-arrow-up-right icon-link" />
                    </div>

                    <h3 class="report-client">{report.data.client}</h3>
                    <p class="report-description">{report.data.description}</p>

                    <div class="report-meta">
                      <div class="meta-item">
                        <i class="ph ph-calendar" />
                        <span>
                          {new Date(report.data.date).toLocaleDateString(
                            'es-ES',
                            {
                              month: 'long',
                              year: 'numeric',
                            }
                          )}
                        </span>
                      </div>
                      <div class="meta-item">
                        <i class="ph ph-user" />
                        <span>{report.data.analyst.split(' ')[0]}</span>
                      </div>
                    </div>

                    {(() => {
                      const logs = accessLogs[report.id] ?? [];
                      const lastLog = logs[0];
                      const uniqueEmails = [
                        ...new Set(logs.map((l) => l.email)),
                      ];
                      return logs.length > 0 ? (
                        <div class="access-log-box">
                          <div class="log-last">
                            <i class="ph-duotone ph-eye" />
                            <span>
                              Último acceso:{' '}
                              <strong>{lastLog.email.split('@')[0]}</strong> —{' '}
                              {new Date(lastLog.ts).toLocaleDateString(
                                'es-CL',
                                {
                                  day: 'numeric',
                                  month: 'short',
                                  hour: '2-digit',
                                  minute: '2-digit',
                                }
                              )}
                            </span>
                          </div>
                          <div class="log-count">
                            <i class="ph-duotone ph-users" />
                            <span>
                              {uniqueEmails.length} visitante
                              {uniqueEmails.length !== 1 ? 's' : ''} ·{' '}
                              {logs.length} acceso{logs.length !== 1 ? 's' : ''}
                            </span>
                          </div>
                        </div>
                      ) : (
                        <div class="access-log-box access-log-empty">
                          <i class="ph-duotone ph-eye-slash" />
                          <span>Sin accesos registrados</span>
                        </div>
                      );
                    })()}
                  </div>
                </a>
              ))}

              {publishedConsultorias.length === 0 && (
                <div class="empty-state">
                  <i class="ph ph-folder-open empty-icon" />
                  <p>No hay reportes publicados en este momento.</p>
                </div>
              )}
            </div>
          </div>
        </div>
      </>
    )
  }
</Layout>

<style>
  .consultoria-wrapper {
    position: relative;
    padding-top: 6rem;
    padding-bottom: 4rem;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .consultoria-wrapper {
      padding-top: 8rem;
      padding-bottom: 5rem;
    }
  }
  @media (min-width: 1024px) {
    .consultoria-wrapper {
      padding-top: 12rem;
      padding-bottom: 8rem;
    }
  }

  .consultoria-container {
    position: relative;
    z-index: 10;
  }

  .admin-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .admin-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    padding: 0.3rem 0.75rem;
    background: rgba(var(--color-accent-rgb), 0.08);
    border: 1px solid rgba(var(--color-accent-rgb), 0.2);
    border-radius: 9999px;
  }

  .admin-logout {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
    opacity: 0.6;
  }

  .admin-logout:hover {
    color: var(--color-red-400);
    opacity: 1;
  }

  .consultoria-header {
    max-width: 56rem;
    margin: 0 auto 3rem;
    text-align: center;
  }
  @media (min-width: 768px) {
    .consultoria-header {
      margin-bottom: 5rem;
    }
  }

  .consultoria-title {
    font-size: clamp(2.25rem, 8vw, 4.5rem);
    font-weight: 900;
    color: var(--color-secondary);
    letter-spacing: -0.05em;
    margin-bottom: 1.25rem;
    line-height: 1.1;
  }

  .accent-text {
    color: var(--color-accent);
  }

  .consultoria-subtitle {
    font-size: clamp(1rem, 3vw, 1.25rem);
    color: var(--color-muted);
    font-weight: 300;
    max-width: 42rem;
    margin: 0 auto;
  }

  .consultoria-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .consultoria-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .consultoria-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .report-card {
    display: block;
    position: relative;
    padding: 0.25rem;
    border-radius: 1.5rem;
    background: linear-gradient(
      to bottom,
      var(--color-surface-subtle),
      transparent
    );
    transition: background 0.5s;
    text-decoration: none;
  }

  .report-card:hover {
    background: linear-gradient(
      to bottom,
      var(--color-accent-subtle),
      transparent
    );
  }

  .report-card-glow {
    position: absolute;
    inset: 0;
    background-color: var(--color-accent);
    opacity: 0;
    filter: blur(20px);
    border-radius: 1.5rem;
    transition: opacity 0.5s;
    z-index: -1;
  }

  .report-card:hover .report-card-glow {
    opacity: 0.2;
  }

  .report-card-content {
    position: relative;
    height: 100%;
    padding: 1.25rem;
    border-radius: 1.25rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s;
  }
  @media (min-width: 480px) {
    .report-card-content {
      padding: 2rem;
    }
  }

  .report-card:hover .report-card-content {
    border-color: var(--color-accent);
  }

  .report-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .report-badge {
    padding: 0.25rem 0.75rem;
    background-color: var(--color-primary);
    color: var(--color-gray-300);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 9999px;
    border: 1px solid var(--color-line);
    transition: all 0.3s;
  }

  .report-card:hover .report-badge {
    background-color: var(--color-accent-subtle);
    color: var(--color-accent);
    border-color: transparent;
  }

  .icon-link {
    font-size: 1.5rem;
    color: var(--color-muted);
    transition: color 0.3s;
  }

  .report-card:hover .icon-link {
    color: var(--color-accent);
  }

  .report-client {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-secondary);
    margin-bottom: 0.75rem;
    transition: color 0.3s;
  }

  .report-card:hover .report-client {
    color: var(--color-accent);
  }

  .report-description {
    color: var(--color-muted);
    margin-bottom: 2rem;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .report-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 5rem 0;
    color: var(--color-muted);
  }

  .empty-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    opacity: 0.2;
  }

  /* --- Log de accesos admin --- */
  .access-log-box {
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    background: rgba(var(--color-accent-rgb), 0.06);
    border: 1px solid rgba(var(--color-accent-rgb), 0.15);
    border-radius: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .access-log-box.access-log-empty {
    background: transparent;
    border-color: var(--color-line);
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.5;
  }

  .log-last,
  .log-count {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .log-last strong {
    color: var(--color-secondary);
    font-weight: 600;
  }

  .log-last i,
  .log-count i {
    color: var(--color-accent);
    font-size: 0.9rem;
    flex-shrink: 0;
  }
</style>
