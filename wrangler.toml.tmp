#:schema node_modules/wrangler/config-schema.json
name = "agencia-zutra"
pages_build_output_dir = "dist"
compatibility_date = "2025-01-01"
compatibility_flags = ["nodejs_compat"]

[vars]
# Required: BREVO_API_KEY, BREVO_LIST_ID, PUBLIC_GTM_ID, PUBLIC_TURNSTILE_SITE_KEY, TURNSTILE_SECRET_KEY
# (Las variables de Contentful se leerán automáticamente desde el Dashboard de Cloudflare)

# [[kv_namespaces]]
# binding = "SESSION"
# id = "SESSION_KV_ID_FROM_DASHBOARD" # Reemplazar con el ID real en el Dashboard de Cloudflare
