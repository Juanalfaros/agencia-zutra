{
  "name": "agencia-zutra",
  "type": "module",
  "version": "2.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && echo '{\"name\":\"agencia-zutra\",\"compatibility_date\":\"2025-01-01\",\"pages_build_output_dir\":\"../client\",\"compatibility_flags\":[\"nodejs_compat\"]}' > dist/server/wrangler.json && cp -r dist/server/* dist/client/ && mv dist/client/entry.mjs dist/client/_worker.js",
    "preview": "astro preview",
    "astro": "astro",
    "migrate": "tsx scripts/migrate-to-contentful.ts",
    "lint": "eslint . --ext .js,.ts,.astro",
    "lint:fix": "eslint . --ext .js,.ts,.astro --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.3",
    "@astrojs/sitemap": "^3.7.1",
    "@contentful/live-preview": "^4.9.11",
    "@contentful/rich-text-html-renderer": "^17.1.6",
    "@contentful/rich-text-types": "^17.2.5",
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/simple-icons": "^1.2.75",
    "@nanostores/persistent": "^1.3.3",
    "@phosphor-icons/web": "^2.1.2",
    "astro": "^6.0.8",
    "astro-icon": "^1.1.5",
    "contentful": "^11.12.0",
    "nanostores": "^1.2.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "contentful-management": "^11.75.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "wrangler": "^4.77.0"
  }
}
